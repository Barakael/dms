# Copy relevant values into /var/www/dms/backend/.env on the server

APP_NAME="Company DMS"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://dms.teratech.co.tz

SANCTUM_STATEFUL_DOMAINS=dms.teratech.co.tz

# Database — set for your server MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dms
DB_USERNAME=dms
DB_PASSWORD=your_secure_password

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

# Frontend uses same-origin /api — no VITE_API_URL needed when built on server
